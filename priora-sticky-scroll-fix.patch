index 79ef35d..fb26119 100644
--- a/src/real-styles.css
+++ b/src/real-styles.css
@@ -82,6 +82,17 @@ body {
   line-height: 1.5;
   transition: background .2s, color .2s;
   overflow-x: hidden;
+  /* ⚠️ تصحيح خلل حقيقي: كان overflow-x فقط محدَّد هنا (بدون overflow-y). حسب
+     قاعدة CSS الرسمية، لو أحد المحورين (x أو y) غير "visible" والآخر "visible"
+     (القيمة الافتراضية)، فالمتصفح يحوّل القيمة الافتراضية تلقائياً لـ"auto" —
+     يعني body صار "حاوية تمرير" مستقلة فعلياً بدون ما نقصد، منفصلة عن تمرير
+     الصفحة الطبيعي (html/viewport). وجود حاويتي تمرير متداخلتين (html وbody)
+     بنفس اللحظة هو سبب شائع معروف لكسر position:sticky (التوب بار والسايد بار)
+     — يصير غير واضح لأي حاوية "ينتمي" التمرير فعلياً، فيتحركان مع المحتوى بدل
+     ما يثبتان بالأعلى. الحل: تحديد overflow-y بشكل صريح أيضاً (auto)، فما تبقى
+     أي قيمة ضمنية غامضة، ويرجع التمرير كله لحاوية واحدة واضحة.
+  */
+  overflow-y: auto;
   /* ⚠️ إضافة بطلب صريح: تحسين وضوح الخطوط الصغيرة بشكل عام بكل التطبيق — خصوصاً
      النصوص الفاتحة على خلفية داكنة، اللي كانت تبدو رفيعة وغير واضحة بدون هذا. */
   -webkit-font-smoothing: antialiased;
