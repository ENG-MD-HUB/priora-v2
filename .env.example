# انسخ هذا الملف لـ .env واعبّي القيم بمفاتيح مشروع Firebase الحقيقي تبعك
# (نفس المشروع المستخدم بالنسخة الحالية المنشورة 2.3.0 على Vercel).
#
# تجدها بـ: Firebase Console → Project Settings → عام → "Your apps" → SDK setup and configuration

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
